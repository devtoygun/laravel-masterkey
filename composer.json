{
    "name": "devtoygun/laravel-masterkey",
    "description": "A master key package for laravel projects that bypasses session privileges.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Alihan Toygun",
            "email": "dev.toygun@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^9.52|^10.0|^11.0",
        "illuminate/http": "^9.52|^10.0|^11.0",
        "illuminate/auth": "^9.52|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "DevToygun\\MasterKey\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DevToygun\\MasterKey\\MasterKeyServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}